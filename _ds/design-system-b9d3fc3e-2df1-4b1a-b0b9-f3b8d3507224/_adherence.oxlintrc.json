{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/feedback/**",
              "components/forms/**",
              "components/layout/**",
              "ui_kits/landing_page/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Roboto|Roboto Mono))/i]",
        "message": "Font not provided by the design system. Available: Roboto, Roboto Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccordionItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|title|content|key|ref|className|style|children)$/]",
        "message": "<AccordionItem> doesn't accept that prop. Declared props: id, title, content."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|secondary|info|warning)$/]",
        "message": "<Badge> variant must be one of 'default' | 'secondary' | 'info' | 'warning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium|large)$/]",
        "message": "<Badge> size must be one of 'small' | 'medium' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|children|onClick|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, children, onClick, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium|large)$/]",
        "message": "<Button> size must be one of 'small' | 'medium' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|elevation|padding|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, elevation, padding, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:xs|sm|base|md|lg)$/]",
        "message": "<Card> elevation must be one of 'xs' | 'sm' | 'base' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|checked|onChange|disabled|required|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: id, label, checked, onChange, disabled, required."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|buttonText|buttonOnClick|backgroundImage|backgroundOverlay|key|ref|className|style|children)$/]",
        "message": "<Hero> doesn't accept that prop. Declared props: title, subtitle, buttonText, buttonOnClick, backgroundImage, backgroundOverlay."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|placeholder|value|onChange|error|disabled|label|required|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: type, placeholder, value, onChange, error, disabled, label, required."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
